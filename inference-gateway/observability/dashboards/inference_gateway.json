{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "LLM Inference Gateway",
  "uid": "llm-inference-gateway",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(vllm_kv_cache_usage_perc, cluster)",
        "refresh": 2
      },
      {
        "name": "node",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(vllm_kv_cache_usage_perc{cluster=~\"$cluster\"}, node)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "🟢 Requests / Second",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(vllm_decode_requests_total{status=\"success\"}[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "⏱ Time to First Token p99 (ms)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm_time_to_first_token_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "TTFT p99"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "⚡ Inter-Token Latency p99 (ms)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm_inter_token_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "ITL p99"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "🎯 Prefix Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "avg(vllm_prefix_cache_hit_rate)",
          "legendFormat": "hit rate"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "❌ Error Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(vllm_decode_requests_total{status=\"error\"}[5m])) / sum(rate(vllm_decode_requests_total[5m]))",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.005 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "KV-Cache Utilization Heatmap (by node)",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "vllm_kv_cache_usage_perc{cluster=~\"$cluster\", node=~\"$node\"}",
          "legendFormat": "{{node}}"
        }
      ],
      "options": {
        "calculate": false,
        "color": {
          "scheme": "RdYlGn",
          "steps": 64
        },
        "yAxis": { "decimals": 0, "unit": "percent" }
      }
    },
    {
      "id": 11,
      "title": "Request Queue Depth (by node)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "vllm_num_requests_waiting{node=~\"$node\"}",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "TTFT Distribution (heatmap)",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(vllm_time_to_first_token_seconds_bucket[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 21,
      "title": "Disaggregation Pipeline",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "avg(vllm_num_requests_waiting{role=\"prefill-worker\"})",
          "legendFormat": "Prefill queue"
        },
        {
          "expr": "avg(vllm_num_requests_waiting{role=\"decode-worker\"})",
          "legendFormat": "Decode queue"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm_kv_transfer_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "KV transfer p99 (ms)"
        }
      ]
    }
  ]
}
